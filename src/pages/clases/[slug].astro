---
import Layout from '@/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const clases = await getCollection('clases', (entry) => !entry.data.draft);
	return clases.map((entry) => ({
		params: { slug: entry.id },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const enfoqueLabel = {
	conceptual: 'Conceptual',
	practico: 'Práctico',
	'teorico-practico': 'Teórico + Práctico'
}[entry.data.enfoque];
---

<Layout>
	<div class="h-screen overflow-y-auto scroll-smooth">
		<!-- Header de la clase -->
		<header class="border-b border-content/10 px-12 py-8 max-sm:px-6">
			<div class="mx-auto max-w-6xl">
				<a
					href={import.meta.env.BASE_URL}
					class="mb-6 inline-block font-mono text-xs tracking-widest text-content/40 uppercase transition-colors hover:text-primary"
				>
					Volver
				</a>
				<div class="flex flex-wrap items-start justify-between gap-4">
					<div>
						<p class="mb-2 font-mono text-xs tracking-widest text-content/40 uppercase">
							Clase {String(entry.data.clase).padStart(2, '0')}
						</p>
						<h1 class="mb-3 text-4xl font-bold text-primary">{entry.data.title}</h1>
						<p class="max-w-6xl leading-7 text-content/60">{entry.data.description}</p>
					</div>
				</div>
				<!-- Metadata -->
				<div class="mt-6 flex flex-wrap gap-6">
					<span class="font-mono text-xs text-content/40">⏱ {entry.data.duracion}</span>
					<span class="font-mono text-xs text-content/40">{entry.data.dificultad}</span>
					<span class="font-mono text-xs text-content/40">[ {enfoqueLabel} ]</span>
				</div>
				<!-- Recursos opcionales -->
				{
					entry.data.recursos && entry.data.recursos.length > 0 && (
						<div class="mt-6 flex flex-wrap gap-3">
							{entry.data.recursos.map((r) => (
								<a
									href={r.url}
									target="_blank"
									rel="noopener noreferrer"
									class="rounded border border-content/10 px-3 py-1 font-mono text-xs text-content/50 transition-colors hover:border-primary/40 hover:text-primary"
								>
									↗ {r.titulo}
								</a>
							))}
						</div>
					)
				}
			</div>
		</header>
	</div>
</Layout>
