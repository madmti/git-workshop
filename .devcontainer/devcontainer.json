{
	"name": "Astro Workshop (Node 22 + pnpm 10)",

	// Imagen oficial de Microsoft con Node 22 preinstalado
	"image": "mcr.microsoft.com/devcontainers/javascript-node:22",

	// Característica oficial para inyectar pnpm v10 limpiamente
	"features": {
		"ghcr.io/devcontainers/features/node-pnpm:1": {
			"version": "10"
		}
	},

	// Se ejecuta automáticamente al crear el contenedor (te ahorra el pnpm install manual)
	"postCreateCommand": "pnpm install",

	// Expone el puerto por defecto de Astro hacia tu máquina/Zed
	"forwardPorts": [4321],

	"portsAttributes": {
		"4321": {
			"label": "Astro Dev Server",
			"onAutoForward": "openBrowser"
		}
	},

	"containerEnv": {
		"NODE_ENV": "development"
	},

	// Extensiones por si alguna vez abres el proyecto en el Codespace web de GitHub
	"customizations": {
		"vscode": {
			"extensions": [
				"astro-build.astro-vscode",
				"bradlc.vscode-tailwindcss",
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode"
			]
		}
	},

	// Corre bajo el usuario 'node' (no-root) para evitar problemas de permisos con pnpm
	"remoteUser": "node"
}
